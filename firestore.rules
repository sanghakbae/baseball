rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 기본: 누구나 읽기 가능, 쓰기는 금지(수집기는 Admin SDK로 규칙 우회)
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
    // 방문자 카운터: 클라이언트가 증가시킬 수 있도록 읽기/쓰기 허용
    // (간단한 집계용. 악용 시 App Check 또는 Cloud Function으로 보호 권장)
    match /meta/visitors {
      allow read, write: if true;
    }
  }
}
