rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 방문자 카운터: 클라이언트가 증가시킬 수 있도록 허용
    match /meta/visitors {
      allow read, write: if true;
    }

    // sanghak.kr 대시보드 방문자 카운터(별도 문서)
    match /meta/visitors-sanghak {
      allow read, write: if true;
    }

    // 순위 변동 스냅샷: 클라이언트가 분 단위로 기록(같은 분=같은 문서로 합쳐짐)
    match /rankSnapshots/{id} {
      allow read: if true;
      allow write: if true;
    }

    // 타율왕 예측 투표: 집계 카운터(클라이언트 증가 허용)
    match /meta/votes {
      allow read, write: if true;
    }

    // 알려진 유입처(referrer) 집합 — 새 유입처 알림 판단용
    match /meta/refSources {
      allow read, write: if true;
    }

    // 이정후 경기 알림 dedup (경기당 1회)
    match /meta/leeGameAlert {
      allow read, write: if true;
    }

    // 방문 로그(IP·위치·유입경로): 생성은 누구나, 읽기는 관리자 계정만(개인정보 보호)
    match /visits/{id} {
      allow create: if true;
      allow read, delete: if request.auth != null
                  && request.auth.token.email in [
                       'totoriverce@gmail.com',
                       'totoriverce@baseball-93c5d.firebaseapp.com'
                     ];
      allow update: if false;
    }

    // 익명 응원 게시판: 누구나 읽기, 생성 가능. 수정은 좋아요(likes)만 허용.
    match /cheers/{id} {
      allow read: if true;
      allow create: if request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 200;
      allow update: if request.resource.data.text == resource.data.text
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);
      allow delete: if request.auth != null
                    && request.auth.token.email in [
                         'totoriverce@gmail.com',
                         'totoriverce@baseball-93c5d.firebaseapp.com'
                       ];
    }

    // 그 외: 읽기만 허용(수집기는 Admin SDK로 규칙 우회)
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
